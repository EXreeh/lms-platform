// CognitiaX AI LMS — Prisma schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum OtpPurpose {
  REGISTER
  PASSWORD_RESET
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum QuestionType {
  MCQ
}

enum ActivityType {
  LOGIN
  COURSE_CREATED
  COURSE_UPDATED
  COURSE_SUBMITTED
  COURSE_APPROVED
  COURSE_REJECTED
  COURSE_PUBLISHED
  COURSE_ARCHIVED
  DELETE_REQUESTED
  DELETE_APPROVED
  ENROLLMENT
  QUIZ_ATTEMPT
  USER_ROLE_CHANGED
  USER_SUSPENDED
  USER_CREATED
  RESOURCE_CREATED
  RESOURCE_REMOVED
  CERTIFICATE_ISSUED
  PAYMENT_COMPLETED
}

enum CourseStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum EntityStatus {
  ACTIVE
  PENDING_DELETE
  DELETED
}

enum ResourceType {
  PDF
  NOTE
  LINK
  ASSIGNMENT
  OTHER
}

enum PaymentStatus {
  CREATED
  PENDING
  CAPTURED
  FAILED
}

model User {
  id            String    @id @default(cuid())
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  email         String    @unique
  password      String
  role          Role      @default(STUDENT)
  emailVerified Boolean   @default(false) @map("email_verified")
  suspended     Boolean   @default(false)
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  courses         Course[]
  enrollments     Enrollment[]
  lessonProgress  LessonProgress[]
  quizAttempts    QuizAttempt[]
  activities      ActivityLog[]
  resources       Resource[]
  certificates    Certificate[]
  payments        Payment[]
  feePlans        FeePlan[]
  feePaymentsRecorded FeePayment[] @relation("FeePaymentRecorder")
  feeRemindersReceived FeeReminder[] @relation("FeeReminderStudent")
  feeRemindersSent     FeeReminder[] @relation("FeeReminderSender")
  batchesTeaching     Batch[]       @relation("BatchTeacher")
  batchMemberships    BatchStudent[]
  messagesSent        Message[]     @relation("MessageSender")
  messageRecipients   MessageRecipient[]
  liveClassesTeaching LiveClass[]   @relation("LiveClassTeacher")
  liveClassRecordings LiveClassRecording[] @relation("RecordingTeacher")
  courseAccess            StudentCourseAccess[] @relation("StudentAccess")
  courseAccessAssigned    StudentCourseAccess[] @relation("AccessAssignedBy")
  teacherSalaries         TeacherSalary[]
  teacherAttendance       TeacherAttendance[]
  teacherLeaveRequests    TeacherLeaveRequest[] @relation("LeaveTeacher")
  leaveRequestsReviewed   TeacherLeaveRequest[] @relation("LeaveReviewer")

  @@index([role, suspended])
  @@map("users")
}

model Course {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  description String      @db.Text
  thumbnail   String?
  thumbnailFileName String? @map("thumbnail_file_name")
  price       Decimal     @default(0) @db.Decimal(10, 2)
  category    String
  level       CourseLevel  @default(BEGINNER)
  status      CourseStatus @default(DRAFT)
  rejectionReason String?  @map("rejection_reason") @db.Text
  deleteStatus EntityStatus @default(ACTIVE) @map("delete_status")
  teacherId   String       @map("teacher_id")
  teacher     User         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  modules     Module[]
  enrollments Enrollment[]
  activities  ActivityLog[]
  resources   Resource[]
  certificates Certificate[]
  payments    Payment[]
  feePlans    FeePlan[]
  batches     Batch[]
  batchCourses BatchCourse[]
  studentAccess StudentCourseAccess[]
  liveClasses  LiveClass[]
  liveClassRecordings LiveClassRecording[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([teacherId])
  @@index([status, deleteStatus, category, level])
  @@map("courses")
}

model Module {
  id           String       @id @default(cuid())
  title        String
  order        Int          @default(0)
  deleteStatus EntityStatus @default(ACTIVE) @map("delete_status")
  courseId     String       @map("course_id")
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons      Lesson[]
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([courseId, order])
  @@map("modules")
}

model Lesson {
  id           String       @id @default(cuid())
  title        String
  description  String?      @db.Text
  videoUrl              String?  @map("video_url")
  videoFileName         String?  @map("video_file_name")
  videoMimeType         String?  @map("video_mime_type")
  videoSize             Int?     @map("video_size")
  videoStorageProvider  String?  @map("video_storage_provider")
  videoStorageKey       String?  @map("video_storage_key")
  duration     Int          @default(0)
  order        Int          @default(0)
  deleteStatus EntityStatus @default(ACTIVE) @map("delete_status")
  moduleId     String       @map("module_id")
  module       Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress     LessonProgress[]
  quizzes      Quiz[]
  resources    Resource[]
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([moduleId, order])
  @@map("lessons")
}

model Enrollment {
  id                 String   @id @default(cuid())
  studentId          String   @map("student_id")
  courseId           String   @map("course_id")
  enrolledAt         DateTime @default(now()) @map("enrolled_at")
  completed          Boolean  @default(false)
  progressPercentage Float    @default(0) @map("progress_percentage")
  updatedAt          DateTime @updatedAt @map("updated_at")

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([studentId])
  @@map("enrollments")
}

model LessonProgress {
  id              String    @id @default(cuid())
  studentId       String    @map("student_id")
  lessonId        String    @map("lesson_id")
  completed       Boolean   @default(false)
  watchedDuration Int       @default(0) @map("watched_duration")
  completedAt     DateTime? @map("completed_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson  Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
  @@index([studentId])
  @@map("lesson_progress")
}

model PendingRegistration {
  id           String   @id @default(cuid())
  email        String   @unique
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  passwordHash String   @map("password_hash")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("pending_registrations")
}

model OtpChallenge {
  id        String     @id @default(cuid())
  email     String
  purpose   OtpPurpose
  codeHash  String     @map("code_hash")
  expiresAt DateTime   @map("expires_at")
  attempts  Int        @default(0)
  verified  Boolean    @default(false)
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([email, purpose, createdAt])
  @@map("otp_challenges")
}

model Quiz {
  id           String       @id @default(cuid())
  title        String
  description  String?      @db.Text
  lessonId     String       @map("lesson_id")
  timeLimit    Int?         @map("time_limit")
  passingScore Float        @default(70) @map("passing_score")
  deleteStatus EntityStatus @default(ACTIVE) @map("delete_status")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  lesson    Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  QuizAttempt[]

  @@index([lessonId])
  @@map("quizzes")
}

model Question {
  id            String       @id @default(cuid())
  quizId        String       @map("quiz_id")
  question      String       @db.Text
  type          QuestionType @default(MCQ)
  options       Json
  correctAnswer String       @map("correct_answer")
  points        Int          @default(1)
  order         Int          @default(0)
  createdAt     DateTime     @default(now()) @map("created_at")

  quiz             Quiz              @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionAttempts QuestionAttempt[]

  @@index([quizId, order])
  @@map("questions")
}

model QuizAttempt {
  id          String    @id @default(cuid())
  quizId      String    @map("quiz_id")
  studentId   String    @map("student_id")
  score       Float     @default(0)
  passed      Boolean   @default(false)
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  quiz             Quiz              @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student          User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  questionAttempts QuestionAttempt[]

  @@index([quizId, studentId])
  @@map("quiz_attempts")
}

model QuestionAttempt {
  id             String  @id @default(cuid())
  quizAttemptId  String  @map("quiz_attempt_id")
  questionId     String  @map("question_id")
  selectedAnswer String? @map("selected_answer")
  correct        Boolean @default(false)

  quizAttempt QuizAttempt @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([quizAttemptId, questionId])
  @@map("question_attempts")
}

model ActivityLog {
  id        String       @id @default(cuid())
  type      ActivityType
  userId    String?      @map("user_id")
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  courseId  String?      @map("course_id")
  course    Course?      @relation(fields: [courseId], references: [id], onDelete: SetNull)
  metadata  Json?
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@map("activity_logs")
}

model Resource {
  id           String       @id @default(cuid())
  title        String
  description  String?      @db.Text
  type         ResourceType
  url          String
  fileName     String?      @map("file_name")
  mimeType     String?      @map("mime_type")
  fileSize     Int?         @map("file_size")
  storageProvider String    @default("local") @map("storage_provider")
  courseId     String       @map("course_id")
  lessonId     String?      @map("lesson_id")
  uploadedById String       @map("uploaded_by_id")
  deleteStatus EntityStatus @default(ACTIVE) @map("delete_status")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  course     Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson     Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  uploadedBy User    @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([courseId, deleteStatus])
  @@index([lessonId, deleteStatus])
  @@index([uploadedById])
  @@map("resources")
}

model Certificate {
  id                String   @id @default(cuid())
  studentId         String   @map("student_id")
  courseId          String   @map("course_id")
  certificateNumber String   @unique @map("certificate_number")
  verificationCode  String   @unique @map("verification_code")
  issuedAt          DateTime @default(now()) @map("issued_at")
  pdfUrl            String?  @map("pdf_url")

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([verificationCode])
  @@index([courseId])
  @@map("certificates")
}

model Payment {
  id                String        @id @default(cuid())
  studentId         String        @map("student_id")
  courseId          String        @map("course_id")
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("INR")
  razorpayOrderId   String        @unique @map("razorpay_order_id")
  razorpayPaymentId String?       @unique @map("razorpay_payment_id")
  razorpaySignature String?       @map("razorpay_signature")
  status            PaymentStatus @default(CREATED)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
  @@index([courseId])
  @@index([status, createdAt])
  @@map("payments")
}

enum FeeStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CARD
  OTHER
}

enum ReminderStatus {
  SENT
  READ
  PENDING
}

enum BatchStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  DELETED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  HALF_DAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MessageType {
  GENERAL
  FEE_REMINDER
  CLASS_UPDATE
  ASSIGNMENT
  ANNOUNCEMENT
}

enum LiveClassStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum RecordingStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum AccessType {
  ADMIN_ASSIGNED
  BATCH_ASSIGNED
  FULL_FEE_PAID
  TRIAL
}

enum SalaryStatus {
  PENDING
  PAID
  HOLD
}

model FeePlan {
  id              String    @id @default(cuid())
  studentId       String    @map("student_id")
  courseId        String?   @map("course_id")
  batchId         String?   @map("batch_id")
  totalAmount     Decimal   @map("total_amount") @db.Decimal(12, 2)
  paidAmount      Decimal   @default(0) @map("paid_amount") @db.Decimal(12, 2)
  pendingAmount   Decimal   @map("pending_amount") @db.Decimal(12, 2)
  dueDate         DateTime  @map("due_date")
  status          FeeStatus @default(PENDING)
  accessGranted   Boolean   @default(false) @map("access_granted")
  lifetimeAccess  Boolean   @default(false) @map("lifetime_access")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  student   User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course    Course?       @relation(fields: [courseId], references: [id], onDelete: SetNull)
  batch     Batch?        @relation(fields: [batchId], references: [id], onDelete: SetNull)
  payments  FeePayment[]
  reminders FeeReminder[]

  @@index([studentId, status])
  @@index([dueDate, status])
  @@map("fee_plans")
}

model FeePayment {
  id           String      @id @default(cuid())
  feePlanId    String      @map("fee_plan_id")
  amount       Decimal     @db.Decimal(12, 2)
  paymentMode  PaymentMode @map("payment_mode")
  paymentDate  DateTime    @map("payment_date")
  note         String?     @db.Text
  recordedById String      @map("recorded_by_id")
  createdAt    DateTime    @default(now()) @map("created_at")

  feePlan    FeePlan @relation(fields: [feePlanId], references: [id], onDelete: Cascade)
  recordedBy User    @relation("FeePaymentRecorder", fields: [recordedById], references: [id], onDelete: Cascade)

  @@index([feePlanId, paymentDate])
  @@map("fee_payments")
}

model FeeReminder {
  id           String         @id @default(cuid())
  studentId    String         @map("student_id")
  feePlanId    String         @map("fee_plan_id")
  message      String         @db.Text
  reminderDate DateTime       @map("reminder_date")
  status       ReminderStatus @default(SENT)
  sentById     String         @map("sent_by_id")
  createdAt    DateTime       @default(now()) @map("created_at")

  student  User    @relation("FeeReminderStudent", fields: [studentId], references: [id], onDelete: Cascade)
  feePlan  FeePlan @relation(fields: [feePlanId], references: [id], onDelete: Cascade)
  sentBy   User    @relation("FeeReminderSender", fields: [sentById], references: [id], onDelete: Cascade)

  @@index([studentId, status])
  @@map("fee_reminders")
}

model Batch {
  id          String      @id @default(cuid())
  name        String
  description String?     @db.Text
  courseId    String?     @map("course_id")
  teacherId   String?     @map("teacher_id")
  startDate   DateTime    @map("start_date")
  endDate     DateTime?   @map("end_date")
  timing      String?
  daysOfWeek  String?     @map("days_of_week")
  status      BatchStatus @default(ACTIVE)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  course      Course?        @relation(fields: [courseId], references: [id], onDelete: SetNull)
  teacher     User?          @relation("BatchTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  students    BatchStudent[]
  courses     BatchCourse[]
  feePlans    FeePlan[]
  messages    Message[]
  liveClasses LiveClass[]
  recordings  LiveClassRecording[]

  @@index([teacherId, status])
  @@index([status, startDate])
  @@map("batches")
}

model BatchCourse {
  id        String   @id @default(cuid())
  batchId   String   @map("batch_id")
  courseId  String   @map("course_id")
  createdAt DateTime @default(now()) @map("created_at")

  batch  Batch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([batchId, courseId])
  @@index([courseId])
  @@map("batch_courses")
}

model StudentCourseAccess {
  id             String     @id @default(cuid())
  studentId      String     @map("student_id")
  courseId       String     @map("course_id")
  assignedById   String     @map("assigned_by_id")
  accessType     AccessType @map("access_type")
  lifetimeAccess Boolean    @default(false) @map("lifetime_access")
  startsAt       DateTime   @default(now()) @map("starts_at")
  expiresAt      DateTime?  @map("expires_at")
  revokedAt      DateTime?  @map("revoked_at")
  createdAt      DateTime   @default(now()) @map("created_at")

  student    User   @relation("StudentAccess", fields: [studentId], references: [id], onDelete: Cascade)
  course     Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  assignedBy User   @relation("AccessAssignedBy", fields: [assignedById], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([studentId, revokedAt])
  @@index([courseId])
  @@map("student_course_access")
}

model TeacherSalary {
  id          String        @id @default(cuid())
  teacherId   String        @map("teacher_id")
  month       Int
  year        Int
  baseSalary  Decimal       @map("base_salary") @db.Decimal(12, 2)
  bonus       Decimal       @default(0) @db.Decimal(12, 2)
  deductions  Decimal       @default(0) @db.Decimal(12, 2)
  netSalary   Decimal       @map("net_salary") @db.Decimal(12, 2)
  status      SalaryStatus  @default(PENDING)
  paidAt      DateTime?     @map("paid_at")
  note        String?       @db.Text
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  teacher User @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, month, year])
  @@index([status, year, month])
  @@map("teacher_salaries")
}

model TeacherAttendance {
  id        String           @id @default(cuid())
  teacherId String           @map("teacher_id")
  date      DateTime         @db.Date
  status    AttendanceStatus
  markedAt  DateTime         @map("marked_at")
  note      String?          @db.Text
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  teacher User @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, date])
  @@index([date, status])
  @@map("teacher_attendance")
}

model TeacherLeaveRequest {
  id           String      @id @default(cuid())
  teacherId    String      @map("teacher_id")
  fromDate     DateTime    @map("from_date") @db.Date
  toDate       DateTime    @map("to_date") @db.Date
  reason       String      @db.Text
  status       LeaveStatus @default(PENDING)
  reviewedById String?     @map("reviewed_by_id")
  reviewedAt   DateTime?   @map("reviewed_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  teacher    User  @relation("LeaveTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("LeaveReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([teacherId, status])
  @@index([status, fromDate])
  @@map("teacher_leave_requests")
}

model BatchStudent {
  id        String   @id @default(cuid())
  batchId   String   @map("batch_id")
  studentId String   @map("student_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  batch   Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([batchId, studentId])
  @@index([studentId])
  @@map("batch_students")
}

model Message {
  id         String      @id @default(cuid())
  senderId   String      @map("sender_id")
  batchId    String?     @map("batch_id")
  feePlanId  String?     @map("fee_plan_id")
  subject    String
  content    String      @db.Text
  type       MessageType @default(GENERAL)
  createdAt  DateTime    @default(now()) @map("created_at")

  sender     User               @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  batch      Batch?             @relation(fields: [batchId], references: [id], onDelete: SetNull)
  recipients MessageRecipient[]

  @@index([senderId, createdAt])
  @@index([batchId, createdAt])
  @@map("messages")
}

model MessageRecipient {
  id        String    @id @default(cuid())
  messageId String    @map("message_id")
  userId    String    @map("user_id")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, readAt])
  @@map("message_recipients")
}

model LiveClass {
  id              String          @id @default(cuid())
  batchId         String          @map("batch_id")
  courseId        String          @map("course_id")
  teacherId       String          @map("teacher_id")
  title           String
  description     String?         @db.Text
  scheduledAt     DateTime        @map("scheduled_at")
  durationMinutes Int             @default(60) @map("duration")
  status          LiveClassStatus @default(SCHEDULED)
  liveUrl         String?         @map("live_url")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  batch      Batch                 @relation(fields: [batchId], references: [id], onDelete: Cascade)
  course     Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher    User                  @relation("LiveClassTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  recordings LiveClassRecording[]

  @@index([batchId, scheduledAt])
  @@index([courseId, scheduledAt])
  @@index([teacherId, scheduledAt])
  @@index([status, scheduledAt])
  @@map("live_classes")
}

model LiveClassRecording {
  id                  String          @id @default(cuid())
  liveClassId         String          @map("live_class_id")
  batchId             String          @map("batch_id")
  courseId            String          @map("course_id")
  teacherId           String          @map("teacher_id")
  title               String
  description         String?         @db.Text
  videoUrl            String          @map("video_url")
  videoStorageKey     String?         @map("video_storage_key")
  videoStorageProvider String?        @map("video_storage_provider")
  videoFileName       String?         @map("video_file_name")
  videoMimeType       String?         @map("video_mime_type")
  videoSize           Int?            @map("video_size")
  durationSeconds     Int?            @map("duration_seconds")
  status              RecordingStatus @default(ACTIVE)
  uploadedAt          DateTime        @default(now()) @map("uploaded_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  liveClass LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  batch     Batch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher   User      @relation("RecordingTeacher", fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([liveClassId, status])
  @@index([batchId, status])
  @@index([courseId, status])
  @@index([teacherId, uploadedAt])
  @@map("live_class_recordings")
}
