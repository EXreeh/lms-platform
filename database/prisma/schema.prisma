// Cognitiax AI LMS — Prisma schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum OtpPurpose {
  REGISTER
  PASSWORD_RESET
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum QuestionType {
  MCQ
}

enum ActivityType {
  LOGIN
  COURSE_CREATED
  COURSE_UPDATED
  COURSE_SUBMITTED
  COURSE_APPROVED
  COURSE_REJECTED
  COURSE_PUBLISHED
  COURSE_ARCHIVED
  DELETE_REQUESTED
  DELETE_APPROVED
  ENROLLMENT
  QUIZ_ATTEMPT
  USER_ROLE_CHANGED
  USER_SUSPENDED
  USER_CREATED
}

enum CourseStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum EntityStatus {
  ACTIVE
  PENDING_DELETE
  DELETED
}

model User {
  id            String    @id @default(cuid())
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  email         String    @unique
  password      String
  role          Role      @default(STUDENT)
  emailVerified Boolean   @default(false) @map("email_verified")
  suspended     Boolean   @default(false)
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  courses         Course[]
  enrollments     Enrollment[]
  lessonProgress  LessonProgress[]
  quizAttempts    QuizAttempt[]
  activities      ActivityLog[]

  @@index([role, suspended])
  @@map("users")
}

model Course {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  description String      @db.Text
  thumbnail   String?
  price       Decimal     @default(0) @db.Decimal(10, 2)
  category    String
  level       CourseLevel  @default(BEGINNER)
  status      CourseStatus @default(DRAFT)
  deleteStatus EntityStatus @default(ACTIVE) @map("delete_status")
  teacherId   String       @map("teacher_id")
  teacher     User         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  modules     Module[]
  enrollments Enrollment[]
  activities  ActivityLog[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([teacherId])
  @@index([status, deleteStatus, category, level])
  @@map("courses")
}

model Module {
  id           String       @id @default(cuid())
  title        String
  order        Int          @default(0)
  deleteStatus EntityStatus @default(ACTIVE) @map("delete_status")
  courseId     String       @map("course_id")
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons      Lesson[]
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([courseId, order])
  @@map("modules")
}

model Lesson {
  id           String       @id @default(cuid())
  title        String
  description  String?      @db.Text
  videoUrl     String?      @map("video_url")
  duration     Int          @default(0)
  order        Int          @default(0)
  deleteStatus EntityStatus @default(ACTIVE) @map("delete_status")
  moduleId     String       @map("module_id")
  module       Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress     LessonProgress[]
  quizzes      Quiz[]
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([moduleId, order])
  @@map("lessons")
}

model Enrollment {
  id                 String   @id @default(cuid())
  studentId          String   @map("student_id")
  courseId           String   @map("course_id")
  enrolledAt         DateTime @default(now()) @map("enrolled_at")
  completed          Boolean  @default(false)
  progressPercentage Float    @default(0) @map("progress_percentage")
  updatedAt          DateTime @updatedAt @map("updated_at")

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([studentId])
  @@map("enrollments")
}

model LessonProgress {
  id              String    @id @default(cuid())
  studentId       String    @map("student_id")
  lessonId        String    @map("lesson_id")
  completed       Boolean   @default(false)
  watchedDuration Int       @default(0) @map("watched_duration")
  completedAt     DateTime? @map("completed_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson  Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
  @@index([studentId])
  @@map("lesson_progress")
}

model PendingRegistration {
  id           String   @id @default(cuid())
  email        String   @unique
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  passwordHash String   @map("password_hash")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("pending_registrations")
}

model OtpChallenge {
  id        String     @id @default(cuid())
  email     String
  purpose   OtpPurpose
  codeHash  String     @map("code_hash")
  expiresAt DateTime   @map("expires_at")
  attempts  Int        @default(0)
  verified  Boolean    @default(false)
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([email, purpose, createdAt])
  @@map("otp_challenges")
}

model Quiz {
  id           String       @id @default(cuid())
  title        String
  description  String?      @db.Text
  lessonId     String       @map("lesson_id")
  timeLimit    Int?         @map("time_limit")
  passingScore Float        @default(70) @map("passing_score")
  deleteStatus EntityStatus @default(ACTIVE) @map("delete_status")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  lesson    Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  QuizAttempt[]

  @@index([lessonId])
  @@map("quizzes")
}

model Question {
  id            String       @id @default(cuid())
  quizId        String       @map("quiz_id")
  question      String       @db.Text
  type          QuestionType @default(MCQ)
  options       Json
  correctAnswer String       @map("correct_answer")
  points        Int          @default(1)
  order         Int          @default(0)
  createdAt     DateTime     @default(now()) @map("created_at")

  quiz             Quiz              @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionAttempts QuestionAttempt[]

  @@index([quizId, order])
  @@map("questions")
}

model QuizAttempt {
  id          String    @id @default(cuid())
  quizId      String    @map("quiz_id")
  studentId   String    @map("student_id")
  score       Float     @default(0)
  passed      Boolean   @default(false)
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  quiz             Quiz              @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student          User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  questionAttempts QuestionAttempt[]

  @@index([quizId, studentId])
  @@map("quiz_attempts")
}

model QuestionAttempt {
  id             String  @id @default(cuid())
  quizAttemptId  String  @map("quiz_attempt_id")
  questionId     String  @map("question_id")
  selectedAnswer String? @map("selected_answer")
  correct        Boolean @default(false)

  quizAttempt QuizAttempt @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([quizAttemptId, questionId])
  @@map("question_attempts")
}

model ActivityLog {
  id        String       @id @default(cuid())
  type      ActivityType
  userId    String?      @map("user_id")
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  courseId  String?      @map("course_id")
  course    Course?      @relation(fields: [courseId], references: [id], onDelete: SetNull)
  metadata  Json?
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@map("activity_logs")
}
