# CognitiaX AI LMS — root environment reference

DATABASE_URL="postgresql://aster@localhost:5432/lms_platform"

# Backend (see backend/.env.example)
NODE_ENV=development
PORT=4000
JWT_SECRET=change-me-to-a-secure-cognitiax-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=cognitiax_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
CORS_ORIGIN=http://localhost:3000

# Frontend (see frontend/.env.example)
NEXT_PUBLIC_API_URL=http://localhost:3000/api
API_PROXY_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
