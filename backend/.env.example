# CognitiaX AI LMS — Backend

NODE_ENV=development
PORT=4000

# PostgreSQL (Neon or local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/lms_platform?sslmode=require"

# Auth — use a strong random string (min 32 chars) in production
JWT_SECRET=change-me-to-a-secure-cognitiax-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=cognitiax_token
RESET_TOKEN_EXPIRES_IN=15m

# Cookies — production: COOKIE_SECURE=true, COOKIE_SAME_SITE=lax (or none if cross-site)
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
# COOKIE_DOMAIN=.yourdomain.com

# CORS — production frontend URL (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:3000
# CORS_ORIGIN=https://your-app.vercel.app

# OTP
OTP_SECRET=change-me-otp-hmac-secret-key
OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_SENDS_PER_HOUR=5

# Email (Gmail App Password: https://myaccount.google.com/apppasswords)
MAIL_DEV_LOG=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="CognitiaX AI <noreply@cognitiax.ai>"

# File uploads (local development — not for large production videos)
STORAGE_PROVIDER=local
UPLOADS_DIR=uploads
STORAGE_PUBLIC_URL=/uploads
MAX_VIDEO_UPLOAD_MB=500
MAX_RESOURCE_UPLOAD_MB=50

# AWS S3 (future — set STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# Cloudflare R2 (future — set STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Razorpay (optional — not required for deployment)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
