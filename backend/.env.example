# Cognitiax AI LMS — Backend

NODE_ENV=development
PORT=4000

DATABASE_URL="postgresql://aster@localhost:5432/lms_platform"

JWT_SECRET=change-me-to-a-secure-cognitiax-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=cognitiax_token
RESET_TOKEN_EXPIRES_IN=15m

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
CORS_ORIGIN=http://localhost:3000

# OTP
OTP_SECRET=change-me-otp-hmac-secret-key
OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_SENDS_PER_HOUR=5

# Gmail SMTP (use App Password — https://myaccount.google.com/apppasswords)
MAIL_DEV_LOG=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM="Cognitiax AI <your-email@gmail.com>"
