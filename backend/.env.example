# Cognitiax AI LMS — Backend

NODE_ENV=development
PORT=4000

# PostgreSQL (same as database/.env)
DATABASE_URL="postgresql://aster@localhost:5432/lms_platform"

# JWT — use a long random secret in production (min 32 characters)
JWT_SECRET=change-me-to-a-secure-cognitiax-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=cognitiax_token

# Cookie security (set COOKIE_SECURE=true in production behind HTTPS)
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# CORS — frontend origin(s), comma-separated
CORS_ORIGIN=http://localhost:3000
